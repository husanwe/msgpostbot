{
  "name": "msgpostbot",
  "type": "module",
  "scripts": {
    "build": "tsc --outDir dist",
    "start": "node dist/index.js",
    "dev:compose:up": "docker compose -f docker-compose.dev.yaml watch",
    "dev:compose:down": "docker compose -f docker-compose.dev.yaml down -v",
    "dev:compose:logs": "docker compose -f docker-compose.dev.yaml logs -f",
    "lint": "eslint --fix .",
    "format": "prettier --ignore-unknown --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/i18n": "^1.1.2",
    "@grammyjs/storage-redis": "^2.5.1",
    "grammy": "^1.41.1",
    "ioredis": "^5.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
